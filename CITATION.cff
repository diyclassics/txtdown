    family-names: Burns
    orcid: "https://orcid.org/0000-0003-2158-866X"
repository-code: "https://github.com/diyclassics/txtdown"
url: "https://github.com/diyclassics/txtdown"
license: MIT
version: 0.4.0
date-released: "2026-07-22"
keywords:
  - latin
  - markup
  - text
  - philology
  - digital-humanities
  - nlp
  - tei
